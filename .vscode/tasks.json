{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Test: cast",
      "type": "shell",
      "command": "uv run pytest cast/tests",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: photoalbums",
      "type": "shell",
      "command": "uv run pytest photoalbums/tests",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: vhs",
      "type": "shell",
      "command": "uv run pytest vhs/test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Test: all",
      "dependsOn": ["Test: cast", "Test: photoalbums", "Test: vhs"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "MCP HTTP Server (minimized window)",
      "type": "shell",
      "command": "start",
      "args": [
        "/MIN",
        "MCP HTTP Server",
        "cmd.exe",
        "/K",
        "just mcp-http"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/C"]
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "dedicated",
        "clear": false,
        "echo": false,
        "focus": false
      },
      "isBackground": false,
      "problemMatcher": [],
      "runOptions": {
        "reevaluateOnRerun": false
      }
    },
    {
      "label": "Stop MCP HTTP Server",
      "type": "shell",
      "command": "taskkill",
      "args": [
        "/F",
        "/FI",
        "WINDOWTITLE eq MCP HTTP Server*",
        "/T"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}