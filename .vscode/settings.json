{
    "python.testing.pytestArgs": [
        "cast/tests",
        "photoalbums/tests",
        "vhs/test"
    ],
    "python.useEnvironmentsExtension": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python.defaultInterpreterPath": ".venv\\Scripts\\python.exe",
    "python.terminal.activateEnvironment": true,
    "terminal.integrated.profiles.windows": {
        "Imago (Claude Code)": {
          "path": "cmd.exe",
          "args": ["/C", "cd /d C:\\users\\covec\\videos\\imago && claude"]
        },
        "Imago (Codex)": {
          "path": "cmd.exe",
          "args": ["/C", "cd /d C:\\users\\covec\\videos\\imago && codex"]
        }
    },
    "terminal.integrated.focusAfterRun" : true,
    "terminal.integrated.defaultProfile.windows": "imago",
    "chatgpt.commentCodeLensEnabled": false,
    "terminal.explorerKind": "external",
    "terminal.integrated.accessibleViewFocusOnCommandExecution": true,
    "dev.containers.dockerPath": "docker", 
    "dev.containers.executeInWSL": true,
    "VsCodeTaskButtons.tasks": [
    {
      "label": "$(debug-start) Start MCP",
      "task": "MCP HTTP Server (minimized window)",
      "tooltip": "Start the MCP HTTP server in minimized window",
      "alignment": "left",          // or "right" if you prefer it on the other side
      "color": "default"            // can be "error" (red) or "warning" (yellow) for emphasis
    },
    {
      "label": "$(debug-stop) Stop MCP",
      "task": "Stop MCP HTTP Server",
      "tooltip": "Stop/kill the MCP HTTP server",
      "alignment": "left",
      "color": "error"              // red to indicate "danger/stop"
    }
  ]
}
