{
    "python.testing.pytestArgs": [
        "photoalbums/tests",
        "vhs/test"
    ],
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": true,
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    "terminal.integrated.profiles.windows": {
        "imago": {
            "source": "PowerShell",
            "args": ["-NoExit", "-Command", "if (Test-Path '${workspaceFolder}/.venv/Scripts/Activate.ps1') { & '${workspaceFolder}/.venv/Scripts/Activate.ps1' } else { Write-Warning '.venv not found — run: python setup.py' }"]
        }
    },
    "terminal.integrated.defaultProfile.windows": "imago"
}