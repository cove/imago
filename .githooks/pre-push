#!/bin/sh
set -eu

# Preserve Git LFS pre-push behavior when git-lfs is available.
if command -v git-lfs >/dev/null 2>&1; then
  git lfs pre-push "$@"
fi

repo_root="$(git rev-parse --show-toplevel)"
echo "[pre-push] Running test suite..."
cd "$repo_root"
uv run pytest cast/tests photoalbums/tests vhs/test -q
