#!/bin/sh
set -eu

# Preserve Git LFS pre-push behavior when git-lfs is available.
if command -v git-lfs >/dev/null 2>&1; then
  git lfs pre-push "$@"
fi

repo_root="$(git rev-parse --show-toplevel)"
echo "[pre-push] Running Skylos duplicate-code check..."
cd "$repo_root"
uv run python scripts/check_skylos.py
echo "[pre-push] Running Vulture dead-code check..."
uv run python scripts/check_vulture.py
